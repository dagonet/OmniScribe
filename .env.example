# OmniScribe Configuration
# Copy to .env and adjust as needed

# ASR (Speech Recognition)
OMNI_WHISPER_MODEL=large-v3-turbo
OMNI_WHISPER_DEVICE=cuda          # cuda, cpu, auto
OMNI_WHISPER_COMPUTE_TYPE=float16  # float16, int8_float16, int8
# OMNI_WHISPER_LANGUAGE=            # leave empty for auto-detect
OMNI_WHISPER_BATCH_SIZE=16

# OCR (On-Screen Text)
OMNI_OCR_ENGINE=paddleocr
OMNI_OCR_LANGUAGES=["en","de"]
OMNI_OCR_CONFIDENCE_THRESHOLD=0.6
OMNI_OCR_FRAME_INTERVAL=0.5
OMNI_OCR_USE_SCENE_DETECTION=true

# Platform
OMNI_PLATFORM_AUTO_DETECT=true
# OMNI_PLATFORM_OVERRIDE=           # force: tiktok, youtube, instagram
OMNI_UI_FILTER_ENABLED=true

# Merge / Deduplication
OMNI_DEDUP_SIMILARITY_THRESHOLD=0.85
OMNI_DEDUP_STRATEGY=prefer_asr     # prefer_asr, prefer_ocr, keep_both

# LLM Cleanup (optional, requires ollama)
OMNI_LLM_CLEANUP_ENABLED=false
OMNI_LLM_MODEL=llama3
OMNI_LLM_BASE_URL=http://localhost:11434

# Output
OMNI_OUTPUT_FORMAT=json             # json, txt, srt, vtt, md
OMNI_INCLUDE_METADATA=true
OMNI_INCLUDE_CONFIDENCE_SCORES=false

# General
OMNI_TEMP_DIR=/tmp/omniscribe
OMNI_KEEP_TEMP_FILES=false
OMNI_LOG_LEVEL=INFO
